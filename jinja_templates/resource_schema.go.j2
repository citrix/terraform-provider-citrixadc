// {{ model_name }} describes the resource data model.
type {{ model_name }} struct {
	Id types.String `tfsdk:"id"`
{%- for attr in attributes %}
	{{ attr.pascal_name }} {{ attr.type_info.framework_type }} `tfsdk:"{{ attr.name }}"`
{%- endfor %}
}

func (r *{{ resource_type_name }}) Schema(ctx context.Context, req resource.SchemaRequest, resp *resource.SchemaResponse) {
	resp.Schema = schema.Schema{
		Version: 1,
		Attributes: map[string]schema.Attribute{
			"id": schema.StringAttribute{
				Computed:    true,
				Description: "The ID of the {{ resource_name }} resource.",
			},
{%- for attr in attributes %}
			"{{ attr.name }}": {{ attr.type_info.attribute_type }}{
{%- if attr.type_info.element_type %}
				ElementType: {{ attr.type_info.element_type }},
{%- endif %}
{%- if attr.is_required %}
				Required:    true,
{%- endif %}
{%- if attr.is_optional %}
				Optional:    true,
{%- endif %}
{%- if attr.is_computed and not attr.get('is_sensitive', False) %}
				Computed:    true,
{%- endif %}
{%- if attr.get('is_sensitive', False) %}
				Sensitive:    true,
{%- endif %}
{%- if attr.get('is_write_only', False) %}
				WriteOnly:    true,
{%- endif %}
{%- if attr.needs_plan_modifier and attr.plan_modifier_info %}
{%- if attr.original_type == 'string' %}
				PlanModifiers: []planmodifier.String{
					{{ attr.plan_modifier_info.modifier }},
				},
{%- elif attr.original_type == 'integer' %}
				PlanModifiers: []planmodifier.Int64{
					{{ attr.plan_modifier_info.modifier }},
				},
{%- elif attr.original_type == 'boolean' %}
				PlanModifiers: []planmodifier.Bool{
					{{ attr.plan_modifier_info.modifier }},
				},
{%- elif attr.original_type == 'number' %}
				PlanModifiers: []planmodifier.Float64{
					{{ attr.plan_modifier_info.modifier }},
				},
{%- elif attr.original_type == 'string[]' %}
				PlanModifiers: []planmodifier.List{
					{{ attr.plan_modifier_info.modifier }},
				},
{%- else %}
				PlanModifiers: []planmodifier.String{
					{{ attr.plan_modifier_info.modifier }},
				},
{%- endif %}
{%- endif %}
{%- if attr.default_value is not none %}
{%- if attr.original_type == 'integer' %}
				Default:     int64default.StaticInt64({{ attr.default_value }}),
{%- elif attr.original_type == 'boolean' %}
				Default:     booldefault.StaticBool({{ attr.default_value|lower }}),
{%- elif attr.original_type == 'string' %}
				Default:     stringdefault.StaticString("{{ attr.default_value }}"),
{%- elif attr.original_type == 'number' %}
				Default:     float64default.StaticFloat64({{ attr.default_value }}),
{%- endif %}
{%- endif %}
				Description: "{{ attr.description }}",
			},
{%- endfor %}
		},
	}
}

func {{ function_names.get_payload_func }}(ctx context.Context, data *{{ model_name }}) {{ nitro_info.type_name }} {
	tflog.Debug(ctx, "In {{ function_names.get_payload_func }} Function")

	// Create API request body from the model
	{{ resource_name.lower() }} := {{ nitro_info.type_name }}{}

{%- for attr in attributes %}
{%- if attr.get('is_version_tracker', False) %}
	// Skip version tracker attribute: {{ attr.name }}
{%- elif attr.get('is_write_only', False) %}
	// Skip write-only attribute: {{ attr.name }}
{%- elif attr.original_type == 'integer' %}
	if !data.{{ attr.pascal_name }}.IsNull() && !data.{{ attr.pascal_name }}.IsUnknown() {
		{{ resource_name.lower() }}.{{ attr.sentence_name }} = utils.IntPtr(int(data.{{ attr.pascal_name }}.ValueInt64()))
	}
{%- elif attr.original_type == 'boolean' %}
	if !data.{{ attr.pascal_name }}.IsNull() && !data.{{ attr.pascal_name }}.IsUnknown() {
		{{ resource_name.lower() }}.{{ attr.sentence_name }} = data.{{ attr.pascal_name }}.ValueBool()
	}
{%- elif attr.original_type == 'string' %}
	if !data.{{ attr.pascal_name }}.IsNull() && !data.{{ attr.pascal_name }}.IsUnknown() {
		{{ resource_name.lower() }}.{{ attr.sentence_name }} = data.{{ attr.pascal_name }}.ValueString()
	}
{%- elif attr.original_type == 'number' %}
	if !data.{{ attr.pascal_name }}.IsNull() && !data.{{ attr.pascal_name }}.IsUnknown() {
		{{ resource_name.lower() }}.{{ attr.sentence_name }} = data.{{ attr.pascal_name }}.ValueFloat64()
	}
{%- elif attr.original_type == 'string[]' %}
	if !data.{{ attr.pascal_name }}.IsNull() && !data.{{ attr.pascal_name }}.IsUnknown() {
		var {{ attr.name }}List []string
		data.{{ attr.pascal_name }}.ElementsAs(ctx, &{{ attr.name }}List, false)
		{{ resource_name.lower() }}.{{ attr.sentence_name }} = {{ attr.name }}List
	}
{%- elif attr.original_type == 'integer[]' %}
	if !data.{{ attr.pascal_name }}.IsNull() && !data.{{ attr.pascal_name }}.IsUnknown() {
		var {{ attr.name }}List []int
		data.{{ attr.pascal_name }}.ElementsAs(ctx, &{{ attr.name }}List, false)
		{{ resource_name.lower() }}.{{ attr.sentence_name }} = {{ attr.name }}List
	}
{%- endif %}
{%- endfor %}

	return {{ resource_name.lower() }}
}

{%- set has_write_only = attributes | selectattr('is_write_only', 'defined') | selectattr('is_write_only', 'equalto', true) | list | length > 0 %}
{%- if has_write_only %}

func {{ resource_name }}GetThePayloadFromtheConfig(ctx context.Context, data *{{ model_name }}, payload *{{ nitro_info.type_name }}) {
	tflog.Debug(ctx, "In {{ resource_name }}GetThePayloadFromtheConfig Function")

	// Add write-only attributes from config to the provided payload
{%- for attr in attributes %}
{%- if attr.get('is_write_only', False) %}
	// Handle write-only secret attribute: {{ attr.name }} -> {{ attr.original_attr_name }}
	if !data.{{ attr.pascal_name }}.IsNull() {
		{{ attr.original_attr_name }}Wo := data.{{ attr.pascal_name }}.ValueString()
		if {{ attr.original_attr_name }}Wo != "" {
			payload.{{ attr.original_attr_sentence_name }} = {{ attr.original_attr_name }}Wo
		}
	}
{%- endif %}
{%- endfor %}
}
{%- endif %}

func {{ function_names.set_attr_func }}(ctx context.Context, data *{{ model_name }}, getResponseData map[string]interface{}) *{{ model_name }} {
	tflog.Debug(ctx, "In {{ function_names.set_attr_func }} Function")

	// Convert API response to model
{%- for attr in attributes %}
{%- if attr.get('is_secret', False) or attr.get('is_write_only', False) or attr.get('is_version_tracker', False) %}
	// {{ attr.name }} is not returned by NITRO API (secret/ephemeral) - retain from config
{%- elif attr.original_type == 'integer' %}
	if val, ok := getResponseData["{{ attr.name }}"]; ok && val != nil {
		if intVal, err := utils.ConvertToInt64(val); err == nil {
			data.{{ attr.pascal_name }} = types.Int64Value(intVal)
		}
	} else {
		data.{{ attr.pascal_name }} = types.Int64Null()
	}
{%- elif attr.original_type == 'boolean' %}
	if val, ok := getResponseData["{{ attr.name }}"]; ok && val != nil {
		data.{{ attr.pascal_name }} = types.BoolValue(val.(bool))
	} else {
		data.{{ attr.pascal_name }} = types.BoolNull()
	}
{%- elif attr.original_type == 'string' %}
	if val, ok := getResponseData["{{ attr.name }}"]; ok && val != nil {
		data.{{ attr.pascal_name }} = types.StringValue(val.(string))
	} else {
		data.{{ attr.pascal_name }} = types.StringNull()
	}
{%- elif attr.original_type == 'number' %}
	if val, ok := getResponseData["{{ attr.name }}"]; ok && val != nil {
		data.{{ attr.pascal_name }} = types.Float64Value(val.(float64))
	} else {
		data.{{ attr.pascal_name }} = types.Float64Null()
	}
{%- elif attr.original_type == 'string[]' %}
	if val, ok := getResponseData["{{ attr.name }}"]; ok && val != nil {
		if sliceVal, ok := val.([]interface{}); ok {
			stringList := utils.ToStringList(sliceVal)
			listValue, _ := types.ListValueFrom(ctx, types.StringType, stringList)
			data.{{ attr.pascal_name }} = listValue
		} else {
			data.{{ attr.pascal_name }} = types.ListNull(types.StringType)
		}
	} else {
		data.{{ attr.pascal_name }} = types.ListNull(types.StringType)
	}
{%- elif attr.original_type == 'integer[]' %}
	if val, ok := getResponseData["{{ attr.name }}"]; ok && val != nil {
		if sliceVal, ok := val.([]interface{}); ok {
			intList := utils.StringListToIntList(sliceVal)
			listValue, _ := types.ListValueFrom(ctx, types.Int64Type, intList)
			data.{{ attr.pascal_name }} = listValue
		} else {
			data.{{ attr.pascal_name }} = types.ListNull(types.Int64Type)
		}
	} else {
		data.{{ attr.pascal_name }} = types.ListNull(types.Int64Type)
	}
{%- endif %}
{%- endfor %}

	// Set ID for the resource
{%- if id_generation.pattern == 'static' %}
	// Case 1: No unique attributes - static ID
	data.Id = types.StringValue("{{ resource_name }}-config")
{%- elif id_generation.pattern == 'single_unique' %}
	// Case 2: Single unique attribute - use plain value as ID
	data.Id = types.StringValue(fmt.Sprintf("%v", data.{{ id_generation.unique_attrs[0].pascal_name }}.{{ id_generation.unique_attrs[0].value_accessor }}))
{%- elif id_generation.pattern == 'multiple_unique' %}
	// Case 3: Multiple unique attributes - comma-separated key:UrlEncode(value) pairs
	idParts := []string{}
{%- for attr in id_generation.unique_attrs | sort(attribute='name') %}
	idParts = append(idParts, fmt.Sprintf("{{ attr.option_name }}:%s", utils.UrlEncode(fmt.Sprintf("%v", data.{{ attr.pascal_name }}.{{ attr.value_accessor }}))))
{%- endfor %}
	data.Id = types.StringValue(strings.Join(idParts, ","))
{%- endif %}

	return data
}