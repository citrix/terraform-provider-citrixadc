package {{ package_name }}

import (
	"context"
	"fmt"
{%- if resource_impl_imports.strconv %}
	"strconv"
{%- endif %}
{%- if resource_impl_imports.strings %}
	"strings"
{%- endif %}

	"github.com/citrix/adc-nitro-go/service"
{%- if resource_impl_imports.utils %}
	"github.com/citrix/terraform-provider-citrixadc/citrixadc_framework/utils"
{%- endif %}
	"github.com/hashicorp/terraform-plugin-framework/diag"
	"github.com/hashicorp/terraform-plugin-framework/path"
	"github.com/hashicorp/terraform-plugin-framework/resource"
{%- if resource_impl_imports.types %}
	"github.com/hashicorp/terraform-plugin-framework/types"
{%- endif %}
	"github.com/hashicorp/terraform-plugin-log/tflog"
)

{#- ======================================================================
    Resource pattern classification:

    parent_attrs:     attrs with is_get_id=true AND is_delete_id=true
    delete_arg_attrs: attrs with x-unique-attr=true AND is_delete_id=false

    named_resource:       parent_attrs present, no delete_arg_attrs
                          CREATE: AddResource   UPDATE: UpdateResource   DELETE: DeleteResource
    binding_with_parent:  parent_attrs present AND delete_arg_attrs present
                          CREATE: UpdateUnnamedResource   UPDATE: N/A   DELETE: DeleteResourceWithArgs(parent, args)
    global_binding:       no parent_attrs, delete_arg_attrs present
                          CREATE: UpdateUnnamedResource   UPDATE: N/A   DELETE: DeleteResourceWithArgs("", args)
    singleton:            no parent_attrs, no delete_arg_attrs
                          CREATE: UpdateUnnamedResource   UPDATE: UpdateUnnamedResource   DELETE: no-op
    ====================================================================== -#}
{%- set parent_attrs = attributes | selectattr('is_get_id', 'equalto', true) | selectattr('is_delete_id', 'equalto', true) | list %}
{%- set delete_arg_attrs = attributes | selectattr('x-unique-attr', 'defined') | selectattr('x-unique-attr', 'equalto', true) | selectattr('is_delete_id', 'equalto', false) | list %}
{%- set is_named_resource = parent_attrs | length > 0 and delete_arg_attrs | length == 0 %}
{%- set is_binding_with_parent = parent_attrs | length > 0 and delete_arg_attrs | length > 0 %}
{%- set is_global_binding = parent_attrs | length == 0 and delete_arg_attrs | length > 0 %}
{%- set is_singleton = parent_attrs | length == 0 and delete_arg_attrs | length == 0 %}

{#- Macro to render ParseIdString arguments from legacy_id_attr_order / legacy_id_optional_attrs -#}
{%- macro parse_id_args() -%}
{%- if legacy_id_attr_order | length > 0 -%}
[]string{ {%- for a in legacy_id_attr_order %}"{{ a }}"{{ ", " if not loop.last }}{% endfor -%} }
{%- else -%}
nil
{%- endif -%}
, {% if legacy_id_optional_attrs | length > 0 -%}
[]string{ {%- for a in legacy_id_optional_attrs %}"{{ a }}"{{ ", " if not loop.last }}{% endfor -%} }
{%- else -%}
nil
{%- endif -%}
{%- endmacro %}

{%- set required_secret_attrs = attributes | selectattr('was_required_secret', 'defined') | selectattr('was_required_secret', 'equalto', true) | selectattr('is_write_only', 'undefined') | list %}
{%- set required_secret_attrs2 = attributes | selectattr('was_required_secret', 'defined') | selectattr('was_required_secret', 'equalto', true) | rejectattr('is_write_only', 'defined') | list %}
{#- Get original secret attrs that were required (not the _wo variants) -#}
{%- set required_secret_originals = [] %}
{%- for attr in attributes %}
{%- if attr.get('was_required_secret', False) and attr.get('is_secret', False) %}
{%- if required_secret_originals.append(attr) %}{% endif %}
{%- endif %}
{%- endfor %}

// Ensure provider defined types fully satisfy framework interfaces.
var _ resource.Resource = &{{ resource_struct_name }}{}
var _ resource.ResourceWithConfigure = (*{{ resource_struct_name }})(nil)
var _ resource.ResourceWithImportState = (*{{ resource_struct_name }})(nil)
{%- if required_secret_originals | length > 0 %}
var _ resource.ResourceWithValidateConfig = (*{{ resource_struct_name }})(nil)
{%- endif %}

func New{{ resource_struct_name }}() resource.Resource {
	return &{{ resource_struct_name }}{}
}

// {{ resource_struct_name }} defines the resource implementation.
type {{ resource_struct_name }} struct {
	client *service.NitroClient
}

func (r *{{ resource_struct_name }}) ImportState(ctx context.Context, req resource.ImportStateRequest, resp *resource.ImportStateResponse) {
	resource.ImportStatePassthroughID(ctx, path.Root("id"), req, resp)
}

func (r *{{ resource_struct_name }}) Metadata(ctx context.Context, req resource.MetadataRequest, resp *resource.MetadataResponse) {
	resp.TypeName = req.ProviderTypeName + "_{{ resource_name }}"
}

func (r *{{ resource_struct_name }}) Configure(ctx context.Context, req resource.ConfigureRequest, resp *resource.ConfigureResponse) {
	// Prevent panic if the provider has not been configured.
	if req.ProviderData == nil {
		return
	}
	// Set the client for the resource.
	r.client = *req.ProviderData.(**service.NitroClient)
}

{%- if required_secret_originals | length > 0 %}

func (r *{{ resource_struct_name }}) ValidateConfig(ctx context.Context, req resource.ValidateConfigRequest, resp *resource.ValidateConfigResponse) {
	var data {{ model_name }}
	resp.Diagnostics.Append(req.Config.Get(ctx, &data)...)
	if resp.Diagnostics.HasError() {
		return
	}
{%- for attr in required_secret_originals %}

	// Validate that either {{ attr.name }} or {{ attr.name }}_wo is specified
	if data.{{ attr.pascal_name }}.IsNull() && data.{{ attr.pascal_name }}Wo.IsNull() {
		resp.Diagnostics.AddAttributeError(
			path.Root("{{ attr.name }}"),
			"Missing Required Attribute",
			"Either \"{{ attr.name }}\" or \"{{ attr.name }}_wo\" must be specified.",
		)
	}
{%- endfor %}
}
{%- endif %}

func (r *{{ resource_struct_name }}) Create(ctx context.Context, req resource.CreateRequest, resp *resource.CreateResponse) {
{%- set has_write_only = attributes | selectattr('is_write_only', 'defined') | selectattr('is_write_only', 'equalto', true) | list | length > 0 %}
{%- if has_write_only %}
	var data, config {{ model_name }}

	// Read Terraform plan data into the model
	resp.Diagnostics.Append(req.Plan.Get(ctx, &data)...)
	// Read write-only attributes from config (they are nullified in plan)
	resp.Diagnostics.Append(req.Config.Get(ctx, &config)...)
{%- else %}
	var data {{ model_name }}

	// Read Terraform plan data into the model
	resp.Diagnostics.Append(req.Plan.Get(ctx, &data)...)
{%- endif %}

	if resp.Diagnostics.HasError() {
		return
	}

	tflog.Debug(ctx, "Creating {{ resource_name }} resource")
{%- if has_write_only %}
	// Get payload from plan (regular attributes)
	{{ resource_var_name }} := {{ resource_name }}GetThePayloadFromthePlan(ctx, &data)
	// Add write-only attributes from config to the payload
	{{ resource_name }}GetThePayloadFromtheConfig(ctx, &config, &{{ resource_var_name }})
{%- else %}
	{{ resource_var_name }} := {{ get_payload_func }}(ctx, &data)
{%- endif %}

	// Make API call
{%- if is_named_resource %}
	// Named resource - use AddResource
	{{ parent_attrs[0].name }}_value := data.{{ parent_attrs[0].pascal_name }}.ValueString()
	_, err := r.client.AddResource(service.{{ nitro_service_type }}.Type(), {{ parent_attrs[0].name }}_value, &{{ resource_var_name }})
{%- else %}
	// {{ 'Binding' if is_binding_with_parent or is_global_binding else 'Singleton' }} resource - use UpdateUnnamedResource
	err := r.client.UpdateUnnamedResource(service.{{ nitro_service_type }}.Type(), &{{ resource_var_name }})
{%- endif %}
	if err != nil {
		resp.Diagnostics.AddError("Client Error", fmt.Sprintf("Unable to create {{ resource_name }}, got error: %s", err))
		return
	}

	tflog.Trace(ctx, "Created {{ resource_name }} resource")

	// Set ID for the resource before reading state
{%- if id_generation %}
{%- if id_generation.pattern == 'static' %}
	data.Id = types.StringValue("{{ resource_name }}-config")
{%- elif id_generation.pattern == 'single_unique' %}
	data.Id = types.StringValue(fmt.Sprintf("%v", data.{{ id_generation.unique_attrs[0].pascal_name }}.{{ id_generation.unique_attrs[0].value_accessor }}))
{%- elif id_generation.pattern == 'multiple_unique' %}
	idParts := []string{}
{%- for attr in id_generation.unique_attrs | sort(attribute='name') %}
	idParts = append(idParts, fmt.Sprintf("{{ attr.option_name }}:%s", utils.UrlEncode(fmt.Sprintf("%v", data.{{ attr.pascal_name }}.{{ attr.value_accessor }}))))
{%- endfor %}
	data.Id = types.StringValue(strings.Join(idParts, ","))
{%- endif %}
{%- else %}
	// Fallback: Use empty string as ID
	data.Id = types.StringValue("")
{%- endif %}

	// Read the updated state back
	r.read{{ pascal_name }}FromApi(ctx, &data, &resp.Diagnostics)

	// Save data into Terraform state
	resp.Diagnostics.Append(resp.State.Set(ctx, &data)...)
}

func (r *{{ resource_struct_name }}) Read(ctx context.Context, req resource.ReadRequest, resp *resource.ReadResponse) {
	var data {{ model_name }}

	// Read Terraform prior state data into the model
	resp.Diagnostics.Append(req.State.Get(ctx, &data)...)

	if resp.Diagnostics.HasError() {
		return
	}

	tflog.Debug(ctx, "Reading {{ resource_name }} resource")

	r.read{{ pascal_name }}FromApi(ctx, &data, &resp.Diagnostics)

	// Save updated data into Terraform state
	resp.Diagnostics.Append(resp.State.Set(ctx, &data)...)
}

func (r *{{ resource_struct_name }}) Update(ctx context.Context, req resource.UpdateRequest, resp *resource.UpdateResponse) {
{%- set has_write_only = attributes | selectattr('is_write_only', 'defined') | selectattr('is_write_only', 'equalto', true) | list | length > 0 %}
{%- if has_write_only %}
	var data, config, state {{ model_name }}
{%- else %}
	var data, state {{ model_name }}
{%- endif %}

	// Read Terraform prior state to preserve ID
	resp.Diagnostics.Append(req.State.Get(ctx, &state)...)
	// Read Terraform plan data into the model
	resp.Diagnostics.Append(req.Plan.Get(ctx, &data)...)
{%- if has_write_only %}
	// Read write-only attributes from config (they are nullified in plan)
	resp.Diagnostics.Append(req.Config.Get(ctx, &config)...)
{%- endif %}

	if resp.Diagnostics.HasError() {
		return
	}

	// Preserve ID from prior state
	data.Id = state.Id

	tflog.Debug(ctx, "Updating {{ resource_name }} resource")

	// Check if there are any changes in updateable attributes
	hasChange := false
{%- for attr in attributes %}
{%- if attr.get('is_secret', False) and not attr.get('is_write_only', False) and not attr.get('is_version_tracker', False) %}
	// Check secret attribute {{ attr.name }} or its version tracker
{%- if attr.original_type == 'string' %}
	if !data.{{ attr.pascal_name }}.Equal(state.{{ attr.pascal_name }}) {
		tflog.Debug(ctx, fmt.Sprintf("{{ attr.name }} has changed for {{ resource_name }}"))
		hasChange = true
	} else if !data.{{ attr.pascal_name }}WoVersion.Equal(state.{{ attr.pascal_name }}WoVersion) {
		tflog.Debug(ctx, fmt.Sprintf("{{ attr.name }}_wo_version has changed for {{ resource_name }}"))
		hasChange = true
	}
{%- endif %}
{%- elif not attr.get('is_secret', False) and not attr.get('is_version_tracker', False) and not attr.get('is_write_only', False) and not attr.get('needs_plan_modifier', False) %}
	if !data.{{ attr.pascal_name }}.Equal(state.{{ attr.pascal_name }}) {
		tflog.Debug(ctx, fmt.Sprintf("{{ attr.name }} has changed for {{ resource_name }}"))
		hasChange = true
	}
{%- endif %}
{%- endfor %}

	if hasChange {
		// Create API request body from the model
{%- if has_write_only %}
		// Get payload from plan (regular attributes)
		{{ resource_var_name }} := {{ resource_name }}GetThePayloadFromthePlan(ctx, &data)
		// Add write-only attributes from config to the payload
		{{ resource_name }}GetThePayloadFromtheConfig(ctx, &config, &{{ resource_var_name }})
{%- else %}
		{{ resource_var_name }} := {{ get_payload_func }}(ctx, &data)
{%- endif %}
		// Make API call
{%- if is_named_resource %}
		// Named resource - use UpdateResource
		{{ parent_attrs[0].name }}_value := data.{{ parent_attrs[0].pascal_name }}.ValueString()
		_, err := r.client.UpdateResource(service.{{ nitro_service_type }}.Type(), {{ parent_attrs[0].name }}_value, &{{ resource_var_name }})
{%- else %}
		// {{ 'Binding' if is_binding_with_parent or is_global_binding else 'Singleton' }} resource - use UpdateUnnamedResource
		err := r.client.UpdateUnnamedResource(service.{{ nitro_service_type }}.Type(), &{{ resource_var_name }})
{%- endif %}
		if err != nil {
			resp.Diagnostics.AddError("Client Error", fmt.Sprintf("Unable to update {{ resource_name }}, got error: %s", err))
			return
		}

		tflog.Trace(ctx, "Updated {{ resource_name }} resource")
	} else {
		tflog.Debug(ctx, "No changes detected for {{ resource_name }} resource, skipping update")
	}

	// Read the updated state back
	r.read{{ pascal_name }}FromApi(ctx, &data, &resp.Diagnostics)

	// Save updated data into Terraform state
	resp.Diagnostics.Append(resp.State.Set(ctx, &data)...)
}

func (r *{{ resource_struct_name }}) Delete(ctx context.Context, req resource.DeleteRequest, resp *resource.DeleteResponse) {
	var data {{ model_name }}

	// Read Terraform prior state data into the model
	resp.Diagnostics.Append(req.State.Get(ctx, &data)...)

	if resp.Diagnostics.HasError() {
		return
	}

	tflog.Debug(ctx, "Deleting {{ resource_name }} resource")

{%- if is_named_resource %}
	// Named resource - delete using DeleteResource
	{{ parent_attrs[0].name }}_value := data.{{ parent_attrs[0].pascal_name }}.ValueString()
	err := r.client.DeleteResource(service.{{ nitro_service_type }}.Type(), {{ parent_attrs[0].name }}_value)
	if err != nil {
		resp.Diagnostics.AddError("Client Error", fmt.Sprintf("Unable to delete {{ resource_name }}, got error: %s", err))
		return
	}

	tflog.Trace(ctx, "Deleted {{ resource_name }} resource")
{%- elif is_binding_with_parent %}
	// Binding with parent - delete using DeleteResourceWithArgs
	idMap, _, err := utils.ParseIdString(data.Id.ValueString(), {{ parse_id_args() }})
	if err != nil {
		resp.Diagnostics.AddError("Parse Error", fmt.Sprintf("Unable to parse ID for delete: %s", err))
		return
	}

	{{ parent_attrs[0].name }}_value, ok := idMap["{{ parent_attrs[0].name }}"]
	if !ok {
		resp.Diagnostics.AddError("Parse Error", "Parent attribute '{{ parent_attrs[0].name }}' not found in ID")
		return
	}

	var argsMap map[string]string = make(map[string]string)
{%- for attr in delete_arg_attrs %}
	if val, ok := idMap["{{ attr.name }}"]; ok && val != "" {
		argsMap["{{ attr.name }}"] = val
	}
{%- endfor %}

	err = r.client.DeleteResourceWithArgsMap(service.{{ nitro_service_type }}.Type(), {{ parent_attrs[0].name }}_value, argsMap)
	if err != nil {
		resp.Diagnostics.AddError("Client Error", fmt.Sprintf("Unable to delete {{ resource_name }}, got error: %s", err))
		return
	}

	tflog.Trace(ctx, "Deleted {{ resource_name }} binding")
{%- elif is_global_binding %}
	// Global binding - delete using DeleteResourceWithArgs with empty resource name
{%- if delete_arg_attrs | length == 1 %}
	// Single unique attribute - ID is the plain value
	{{ delete_arg_attrs[0].name }}_value := data.Id.ValueString()
	args := []string{
		fmt.Sprintf("{{ delete_arg_attrs[0].name }}:%s", {{ delete_arg_attrs[0].name }}_value),
	}

	err := r.client.DeleteResourceWithArgs(service.{{ nitro_service_type }}.Type(), "", args)
{%- else %}
	// Multiple unique attributes - parse from ID
	idMap, _, err := utils.ParseIdString(data.Id.ValueString(), {{ parse_id_args() }})
	if err != nil {
		resp.Diagnostics.AddError("Parse Error", fmt.Sprintf("Unable to parse ID for delete: %s", err))
		return
	}

	var argsMap map[string]string = make(map[string]string)
{%- for attr in delete_arg_attrs %}
	if val, ok := idMap["{{ attr.name }}"]; ok && val != "" {
		argsMap["{{ attr.name }}"] = val
	}
{%- endfor %}

	err = r.client.DeleteResourceWithArgsMap(service.{{ nitro_service_type }}.Type(), "", argsMap)
{%- endif %}
	if err != nil {
		resp.Diagnostics.AddError("Client Error", fmt.Sprintf("Unable to delete {{ resource_name }}, got error: %s", err))
		return
	}

	tflog.Trace(ctx, "Deleted {{ resource_name }} binding")
{%- else %}
	// Singleton resource - no delete operation on ADC, just remove from state
	tflog.Trace(ctx, "Removed {{ resource_name }} from Terraform state")
{%- endif %}
}

