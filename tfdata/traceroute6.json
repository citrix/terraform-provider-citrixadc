[
    {
        "option_name": "I",
        "type": "boolean",
        "description": [
            "Use ICMP ECHO for probes."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false
    },
    {
        "option_name": "T",
        "type": "integer",
        "description": [
            "Traffic Domain Id"
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false
    },
    {
        "option_name": "host",
        "type": "string",
        "description": [
            "Destination host IP address or name."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false
    },
    {
        "option_name": "m",
        "type": "integer",
        "description": [
            "Maximum hop value for outgoing probe packets. For Nitro API, default value is taken as 10."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false,
        "default": 64
    },
    {
        "option_name": "n",
        "type": "boolean",
        "description": [
            "Print hop addresses numerically rather than symbolically and numerically."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false
    },
    {
        "option_name": "p",
        "type": "integer",
        "description": [
            "Base port number used in probes."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false,
        "default": 33434
    },
    {
        "option_name": "packetlen",
        "type": "integer",
        "description": [
            "Length (in bytes) of the query packets."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false,
        "default": 44
    },
    {
        "option_name": "q",
        "type": "integer",
        "description": [
            "Number of probes per hop. For Nitro API, default value is taken as 1."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false,
        "default": 3
    },
    {
        "option_name": "r",
        "type": "boolean",
        "description": [
            "Bypass normal routing tables and send directly to a host on an attached network. If the host is not on a directly attached network, an error is returned."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false
    },
    {
        "option_name": "s",
        "type": "string",
        "description": [
            "Source IP address to use in the outgoing query packets. If the IP address does not belong to this appliance,  an error is returned and nothing is sent."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false
    },
    {
        "option_name": "v",
        "type": "boolean",
        "description": [
            "Verbose output. List received ICMP packets other than TIME_EXCEEDED and UNREACHABLE."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false
    },
    {
        "option_name": "w",
        "type": "integer",
        "description": [
            "Time (in seconds) to wait for a response to a query. For Nitro API, defalut value is set to 3."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false,
        "default": 5
    }
]