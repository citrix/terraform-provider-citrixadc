[
    {
        "option_name": "backplanebasedview",
        "type": "string",
        "description": [
            "View based on heartbeat only on bkplane interface"
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": true,
        "is_required": false,
        "default": "DISABLED"
    },
    {
        "option_name": "clid",
        "type": "integer",
        "description": [
            "Unique number that identifies the cluster."
        ],
        "is_get_id": true,
        "is_delete_id": true,
        "is_updateable": false,
        "is_required": true,
        "x-unique-attr": true
    },
    {
        "option_name": "clusterproxyarp",
        "type": "string",
        "description": [
            "This field controls the proxy arp feature in cluster. By default the flag is enabled."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": true,
        "is_required": false,
        "default": "ENABLED"
    },
    {
        "option_name": "deadinterval",
        "type": "integer",
        "description": [
            "Amount of time, in seconds, after which nodes that do not respond to the heartbeats are assumed to be down.If the value is less than 3 sec, set the helloInterval parameter to 200 msec"
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": true,
        "is_required": false,
        "default": 3
    },
    {
        "option_name": "dfdretainl2params",
        "type": "string",
        "description": [
            "flag to add ext l2 header during steering. By default the flag is disabled."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": true,
        "is_required": false,
        "default": "DISABLED"
    },
    {
        "option_name": "hellointerval",
        "type": "integer",
        "description": [
            "Interval, in milliseconds, at which heartbeats are sent to each cluster node to check the health status.Set the value to 200 msec, if the deadInterval parameter is less than 3 sec"
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": true,
        "is_required": false,
        "default": 200
    },
    {
        "option_name": "inc",
        "type": "string",
        "description": [
            "This option is required if the cluster nodes reside on different networks."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": true,
        "is_required": false,
        "default": "DISABLED"
    },
    {
        "option_name": "nodegroup",
        "type": "string",
        "description": [
            "The node group in a Cluster system used for transition from L2 to L3."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": true,
        "is_required": false
    },
    {
        "option_name": "preemption",
        "type": "string",
        "description": [
            "Preempt a cluster node that is configured as a SPARE if an ACTIVE node becomes available."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": true,
        "is_required": false,
        "default": "DISABLED"
    },
    {
        "option_name": "processlocal",
        "type": "string",
        "description": [
            "By turning on this option packets destined to a service in a cluster will not under go any steering."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": true,
        "is_required": false,
        "default": "DISABLED"
    },
    {
        "option_name": "quorumtype",
        "type": "string",
        "description": [
            "Quorum Configuration Choices  - \"Majority\" (recommended) requires majority of nodes to be online for the cluster to be UP. \"None\" relaxes this requirement."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": true,
        "is_required": false,
        "default": "MAJORITY"
    },
    {
        "option_name": "retainconnectionsoncluster",
        "type": "string",
        "description": [
            "This option enables you to retain existing connections on a node joining a Cluster system or when a node is being configured for passive timeout. By default, this option is disabled."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": true,
        "is_required": false
    },
    {
        "option_name": "secureheartbeats",
        "type": "string",
        "description": [
            "By turning on this option cluster heartbeats will have security enabled."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": true,
        "is_required": false,
        "default": "DISABLED"
    },
    {
        "option_name": "syncstatusstrictmode",
        "type": "string",
        "description": [
            "strict mode for sync status of cluster. Depending on the the mode if there are any errors while applying config, sync status is displayed accordingly. By default the flag is disabled."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": true,
        "is_required": false,
        "default": "DISABLED"
    }
]