[
    {
        "option_name": "I",
        "type": "string",
        "description": [
            "Network interface on which to ping, if you have multiple interfaces."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false
    },
    {
        "option_name": "S",
        "type": "string",
        "description": [
            "Source IP address to be used in the outgoing query packets."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false
    },
    {
        "option_name": "T",
        "type": "integer",
        "description": [
            "Traffic Domain Id"
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false
    },
    {
        "option_name": "V",
        "type": "integer",
        "description": [
            "VLAN ID for link local address."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false
    },
    {
        "option_name": "b",
        "type": "integer",
        "description": [
            "Set socket buffer size. If used, should be used with roughly +100 then the datalen (-s option). The default value is 8192."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false
    },
    {
        "option_name": "c",
        "type": "integer",
        "description": [
            "Number of packets to send. The default value is infinite. For Nitro API, defalut value is taken as 5."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false
    },
    {
        "option_name": "hostName",
        "type": "string",
        "description": [
            "Address of host to ping."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false
    },
    {
        "option_name": "i",
        "type": "integer",
        "description": [
            "Waiting time, in seconds. The default value is 1 second."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false
    },
    {
        "option_name": "m",
        "type": "boolean",
        "description": [
            "By default, ping6 asks the kernel to fragment packets to fit into the minimum IPv6 MTU.The -m option will suppress the behavior for unicast packets."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false
    },
    {
        "option_name": "n",
        "type": "boolean",
        "description": [
            "Numeric output only. No name resolution."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false
    },
    {
        "option_name": "p",
        "type": "string",
        "description": [
            "Pattern to fill in packets. Can be up to 16 bytes, useful for diagnosing data-dependent problems."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false
    },
    {
        "option_name": "q",
        "type": "boolean",
        "description": [
            "Quiet output. Only summary is printed. For Nitro API, this flag is set by default"
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false
    },
    {
        "option_name": "s",
        "type": "integer",
        "description": [
            "Data size, in bytes. The default value is 32."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false
    },
    {
        "option_name": "t",
        "type": "integer",
        "description": [
            "Timeout in seconds before ping6 exits"
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false
    }
]