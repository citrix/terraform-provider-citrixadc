[
    {
        "option_name": "ifnum",
        "type": "string",
        "description": [
            "Interface through which the adjacent network device is available, specified in slot/port notation (for example, 1/3). Use spaces to separate multiple entries."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false
    },
    {
        "option_name": "mac",
        "type": "string",
        "description": [
            "MAC address of the adjacent network device."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": true
    },
    {
        "option_name": "neighbor",
        "type": "string",
        "description": [
            "Link-local IPv6 address of the adjacent network device to add to the ND6 table."
        ],
        "is_get_id": false,
        "is_delete_id": true,
        "is_updateable": false,
        "is_required": true,
        "x-unique-attr": true
    },
    {
        "option_name": "nodeid",
        "type": "integer",
        "description": [
            "Unique number that identifies the cluster node."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false
    },
    {
        "option_name": "td",
        "type": "integer",
        "description": [
            "Integer value that uniquely identifies the traffic domain in which you want to configure the entity. If you do not specify an ID, the entity becomes part of the default traffic domain, which has an ID of 0."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false,
        "x-unique-attr": true
    },
    {
        "option_name": "vlan",
        "type": "integer",
        "description": [
            "Integer value that uniquely identifies the VLAN on which the adjacent network device exists."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false
    },
    {
        "option_name": "vtep",
        "type": "string",
        "description": [
            "IP address of the VXLAN tunnel endpoint (VTEP) through which the IPv6 address of this ND6 entry is reachable."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false
    },
    {
        "option_name": "vxlan",
        "type": "integer",
        "description": [
            "ID of the VXLAN on which the IPv6 address of this ND6 entry is reachable."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false
    }
]