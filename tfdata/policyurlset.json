[
    {
        "option_name": "canaryurl",
        "type": "string",
        "description": [
            "Add this URL to this urlset. Used for testing when contents of urlset is kept confidential."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false
    },
    {
        "option_name": "comment",
        "type": "string",
        "description": [
            "Any comments to preserve information about this url set."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false
    },
    {
        "option_name": "delimiter",
        "type": "string",
        "description": [
            "CSV file record delimiter."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false,
        "default": 44
    },
    {
        "option_name": "imported",
        "type": "boolean",
        "description": [
            "when set, display shows all imported urlsets."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false,
        "x-unique-attr": true
    },
    {
        "option_name": "interval",
        "type": "integer",
        "description": [
            "The interval, in seconds, rounded down to the nearest 15 minutes, at which the update of urlset occurs."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false
    },
    {
        "option_name": "matchedid",
        "type": "integer",
        "description": [
            "An ID that would be sent to AppFlow to indicate which URLSet was the last one that matched the requested URL."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false,
        "default": 1
    },
    {
        "option_name": "name",
        "type": "string",
        "description": [
            "Unique name of the url set. Not case sensitive. Must begin with an ASCII letter or underscore (_) character and must contain only alphanumeric and underscore characters. Must not be the name of an existing named expression, pattern set, dataset, string map, or HTTP callout."
        ],
        "is_get_id": true,
        "is_delete_id": true,
        "is_updateable": false,
        "is_required": true,
        "x-unique-attr": true
    },
    {
        "option_name": "overwrite",
        "type": "boolean",
        "description": [
            "Overwrites the existing file."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false
    },
    {
        "option_name": "privateset",
        "type": "boolean",
        "description": [
            "Prevent this urlset from being exported."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false
    },
    {
        "option_name": "rowseparator",
        "type": "string",
        "description": [
            "CSV file row separator."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false,
        "default": 10
    },
    {
        "option_name": "subdomainexactmatch",
        "type": "boolean",
        "description": [
            "Force exact subdomain matching, ex. given an entry 'google.com' in the urlset, a request to 'news.google.com' won't match, if subdomainExactMatch is set."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false
    },
    {
        "option_name": "url",
        "type": "string",
        "description": [
            "URL (protocol, host, path and file name) from where the CSV (comma separated file) file will be imported or exported. Each record/line will one entry within the urlset. The first field contains the URL pattern, subsequent fields contains the metadata, if available. HTTP, HTTPS and FTP protocols are supported. NOTE: The operation fails if the destination HTTPS server requires client certificate authentication for access."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false,
        "x-secret-attr": true
    }
]