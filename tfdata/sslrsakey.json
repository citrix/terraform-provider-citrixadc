[
    {
        "option_name": "aes256",
        "type": "boolean",
        "description": [
            "Encrypt the generated RSA key by using the AES algorithm."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false
    },
    {
        "option_name": "bits",
        "type": "integer",
        "description": [
            "Size, in bits, of the RSA key."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false
    },
    {
        "option_name": "des",
        "type": "boolean",
        "description": [
            "Encrypt the generated RSA key by using the DES algorithm. On the command line, you are prompted to enter the pass phrase (password) that is used to encrypt the key."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false
    },
    {
        "option_name": "des3",
        "type": "boolean",
        "description": [
            "Encrypt the generated RSA key by using the Triple-DES algorithm. On the command line, you are prompted to enter the pass phrase (password) that is used to encrypt the key."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false
    },
    {
        "option_name": "exponent",
        "type": "string",
        "description": [
            "Public exponent for the RSA key. The exponent is part of the cipher algorithm and is required for creating the RSA key."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false,
        "default": "F4"
    },
    {
        "option_name": "keyfile",
        "type": "string",
        "description": [
            "Name for and, optionally, path to the RSA key file. /nsconfig/ssl/ is the default path."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false
    },
    {
        "option_name": "keyform",
        "type": "string",
        "description": [
            "Format in which the RSA key file is stored on the appliance."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false,
        "default": "PEM"
    },
    {
        "option_name": "password",
        "type": "string",
        "description": [
            "Pass phrase to use for encryption if DES or DES3 option is selected."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false,
        "x-secret-attr": true
    },
    {
        "option_name": "pkcs8",
        "type": "boolean",
        "description": [
            "Create the private key in PKCS#8 format."
        ],
        "is_get_id": false,
        "is_delete_id": false,
        "is_updateable": false,
        "is_required": false
    }
